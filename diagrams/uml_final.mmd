classDiagram
    class Owner {
        +string owner_name
        +string available_time
        +dict preferences
        +list pets
        +update_available_time(new_time: str) void
        +update_preferences(new_preferences: dict) void
        +add_pet(pet: Pet) void
        +get_all_tasks() list[Task]
    }

    class Pet {
        +string pet_name
        +string species
        +string breed
        +int age
        +list tasks
        +update_pet_info(...) void
        +add_task(task: Task) void
        +display_pet_info() string
    }

    class Task {
        +string task_name
        +int duration
        +string priority
        +string category
        +bool recurring
        +bool completed
        +string time_of_day
        +string recurrence
        +datetime due_date
        +string pet_name
        +edit_task(...) void
        +mark_completed() Task|None
        +get_task_details() string
    }

    class Scheduler {
        +list list_of_tasks
        +string available_time
        +int available_time_minutes
        +list scheduled_tasks
        +list skipped_tasks
        +list conflicts
        +_parse_available_time(available_time) int
        +load_tasks_from_owner(owner: Owner) void
        +_parse_time(time_value: str) int
        +sort_tasks() void
        +sort_by_time() void
        +filter_tasks_by(completed: bool|None, pet_name: str|None) list[Task]
        +_tasks_overlap(first: Task, second: Task) bool
        +find_conflicts() list[tuple[Task, Task]]
        +get_conflict_warning() string
        +filter_tasks() list[Task]
        +generate_schedule() DailyPlan
        +explain_schedule() string
    }

    class DailyPlan {
        +list scheduled_tasks
        +int total_time_used
        +int remaining_time
        +string explanation
        +display_plan() string
        +display_explanation() string
        +calculate_remaining_time() int
    }

    Owner --> Pet : owns
    Owner --> Scheduler : uses
    Pet --> Task : has
    Scheduler --> Task : manages
    Scheduler --> DailyPlan : generates
